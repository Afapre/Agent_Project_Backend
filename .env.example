# Google Generative AI API Key
# Get from: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Hugging Face API Token
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Tavily API Key for web search
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Ngrok Auth Token for public links
# Get from: https://dashboard.ngrok.com/auth
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# Render deployment
# Set ENABLE_TTS=false on Render to avoid loading the large TTS model at startup.
ENABLE_TTS=false

# Chroma Cloud configuration
# Required if your app uses Chroma Cloud for embeddings.
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# LlamaParse configuration
# Set this to use the cloud parser for better PDF extraction.
LLAMA_CLOUD_API_KEY=

# Gemini embeddings
# Set to true to use Google Gemini embeddings instead of the local SentenceTransformer model.
USE_GEMINI_EMBEDDINGS=false
